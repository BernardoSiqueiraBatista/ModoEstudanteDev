{
    "name": "hipocratesai-backend",
    "version": "1.0.0",
    "description": "",
    "license": "ISC",
    "author": "",
    "type": "commonjs",
    "main": "eslint.config.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "dev:api": "ts-node-dev --respawn --transpile-only src/server.ts",
        "dev:full": "concurrently -k -n api,llm -c cyan,magenta \"npm:dev:api\" \"npm:dev:clinical-llm\"",
        "dev:clinical-llm": "bash scripts/start-clinical-llm.sh",
        "start:clinical-llm": "bash scripts/start-clinical-llm.sh",
        "build": "tsc",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src",
        "test:student": "jest ./src/modules/exams ./src/modules/performance ./src/modules/questions",
        "db:up": "docker compose up -d",
        "db:down": "docker compose down",
        "db:seed": "python3 scripts/students_table_artificial_seed.py",
        "db:setup": "pnpm db:up && echo 'Aguardando o banco iniciar...' && sleep 5 && pnpm db:seed",
        "db:reset": "docker compose down -v && pnpm db:setup"
    },
    "dependencies": {
        "@hipo/contracts": "workspace:*",
        "@asteasolutions/zod-to-openapi": "^6.4.0",
        "@deepgram/sdk": "^5.0.0",
        "@supabase/supabase-js": "^2.99.0",
        "axios": "^1.13.6",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "form-data": "^4.0.5",
        "helmet": "^8.1.0",
        "multer": "^2.1.1",
        "openai": "^6.33.0",
        "pdf-parse": "^2.4.5",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^13.0.0",
        "ws": "^8.20.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/multer": "^2.1.0",
        "@types/node": "^22.0.0",
        "@types/pdf-parse": "^1.1.5",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.18.1",
        "concurrently": "^9.2.1",
        "openapi3-ts": "^4.5.0",
        "eslint": "^10.2.0",
        "jest": "^30.3.0",
        "pino-pretty": "^13.1.3",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.5.0",
        "typescript-eslint": "^8.58.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node"
    }
}
