# =====================================================================
# HipocratesAI Backend — env template
# Copy this file to .env and fill in real values for local development.
# .env is git-ignored; never commit real secrets.
# =====================================================================

# --- Server ---
NODE_ENV=development
PORT=3333
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TZ_OFFSET=-03:00

# --- Supabase (REQUIRED) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Feature flags ---
# Set to "true" only AFTER applying the corresponding migration:
ENABLE_SOFT_DELETE=false
ENABLE_AUDIT_LOG=false
# Required for the consulta-ativa pipeline (migration 003):
ENABLE_CONSULTATIONS=false

# --- OpenAI (required when ENABLE_CONSULTATIONS=true) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo
OPENAI_MAX_INPUT_TOKENS=16000

# --- Deepgram (required when ENABLE_CONSULTATIONS=true) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=pt-BR

# --- RAG tuning ---
RAG_MATCH_THRESHOLD=0.7
RAG_MATCH_COUNT=3
RAG_WEB_FALLBACK_THRESHOLD=0.7

# --- AI pipeline throttling ---
INSIGHTS_DEBOUNCE_MS=1500
INSIGHTS_THROTTLE_MS=800
INSIGHTS_MAX_CALLS_PER_MINUTE=30

# --- Clinical LLM subservice (FastAPI). OFF by default. ---
ENABLE_CLINICAL_LLM=false
CLINICAL_LLM_URL=http://127.0.0.1:8010
# Generate with: openssl rand -hex 32
CLINICAL_LLM_INTERNAL_TOKEN=

# --- Metrics endpoint ---
# When set, GET /metrics requires header: X-Metrics-Token: <value>
METRICS_TOKEN=

# --- WhatsApp gateway (optional) ---
WHATSAPP_GATEWAY_URL=
WHATSAPP_GATEWAY_TOKEN=
